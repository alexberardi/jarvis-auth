# =============================================================================
# jarvis-auth - Environment Template
# =============================================================================
# Copy to .env and fill in values
# Port: 7701
# =============================================================================

# Service URLs are resolved automatically from jarvis-config-service

# -----------------------------------------------------------------------------
# SERVICE DISCOVERY (optional)
# -----------------------------------------------------------------------------
# Account deletion (DELETE /auth/me) makes best-effort downstream purge calls to
# command-center and notifications. URLs are resolved from config-service by
# default; set these to override or when config-service is unavailable.
# JARVIS_CONFIG_URL=http://localhost:7700
# JARVIS_COMMAND_CENTER_URL=http://localhost:7703
# JARVIS_NOTIFICATIONS_URL=http://localhost:7712

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/jarvis_auth_db

# For migrations (use localhost even when running in Docker)
MIGRATIONS_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/jarvis_auth_db

# -----------------------------------------------------------------------------
# JWT CONFIGURATION
# -----------------------------------------------------------------------------
# Secret key for signing JWTs (generate with: openssl rand -hex 32)
AUTH_SECRET_KEY=CHANGE_ME_generate_a_secure_key

# Algorithm for JWT signing
AUTH_ALGORITHM=HS256

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh-token lifetime = how long a session survives without re-login. 14d
# matches the code default; keep it >=7d so mobile users aren't logged out
# weekly. (Was 3 — too short for the "stays signed in for ~a week" expectation.)
REFRESH_TOKEN_EXPIRE_DAYS=14

# Strict refresh-token theft-detection: revoke the WHOLE token family when an
# already-rotated token is replayed. Default false — a benign replay (two
# client refresh paths, a lost response, or an auth restart that wiped the
# in-process grace cache) must not sign out a live session. Turn on only if you
# accept periodic spurious logouts in exchange for stricter theft response.
# REFRESH_TOKEN_REVOKE_FAMILY_ON_REUSE=false

# How long an admin-issued temporary password stays usable before the user
# must ask for a new one (login is refused after expiry).
# TEMP_PASSWORD_EXPIRE_HOURS=24

# -----------------------------------------------------------------------------
# ADMIN
# -----------------------------------------------------------------------------
# Token for admin endpoints (generate with: openssl rand -hex 32)
JARVIS_AUTH_ADMIN_TOKEN=CHANGE_ME_admin_token

# -----------------------------------------------------------------------------
# CENTRALIZED LOGGING (optional)
# -----------------------------------------------------------------------------
# Register this service with jarvis-auth first to get app credentials
JARVIS_APP_ID=jarvis-auth
JARVIS_APP_KEY=CHANGE_ME_get_from_jarvis_auth_admin

# Log levels: DEBUG, INFO, WARNING, ERROR
JARVIS_LOG_CONSOLE_LEVEL=INFO
JARVIS_LOG_REMOTE_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# DOCKER (only needed when running in Docker)
# -----------------------------------------------------------------------------
# Use host.docker.internal to reach host services from container
# DOCKER_HOST_ALIAS=host.docker.internal
